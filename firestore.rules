rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function perms() {
      return get(/databases/$(database)/documents/userPermissions/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && perms().isAdmin == true;
    }

    function canWriteUniverso(universoId) {
      return isAdmin() ||
             (isAuth() && universoId in perms().universos);
    }

    // Aptidões podem pertencer a mais de um universo (`universos`, lista de
    // ids); docs antigos ainda podem ter apenas o campo singular `universo`.
    function canWriteUniversos(universoIds) {
      return isAdmin() ||
             (isAuth() && universoIds.hasOnly(perms().universos));
    }

    function canWriteAptidaoData(data) {
      return isAdmin() ||
        (isAuth() && (
          (data.universos is list && data.universos.hasOnly(perms().universos)) ||
          (data.universo is string && data.universo in perms().universos)
        ));
    }

    // ── userPermissions ────────────────────────────────────────────────────────
    // Cada usuário só lê o próprio documento; apenas admins podem escrever.
    match /userPermissions/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // ── Universo ───────────────────────────────────────────────────────────────
    // Leitura para qualquer usuário autenticado; escrita apenas para admins.
    match /Universo/{universoId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── racas ──────────────────────────────────────────────────────────────────
    // Leitura para qualquer usuário autenticado.
    // Escrita (create/update/delete) baseada no campo `universo` do documento.
    // - create: o universo do novo doc deve ser permitido ao usuário
    // - update: o universo do doc antigo E do novo devem ser permitidos
    //           (impede mover uma raça para outro universo sem permissão)
    // - delete: o universo do doc existente deve ser permitido
    match /racas/{racaId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── classes ────────────────────────────────────────────────────────────────
    match /classes/{classeId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── materiais ──────────────────────────────────────────────────────────────
    match /materiais/{materialId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── itens ──────────────────────────────────────────────────────────────────
    match /itens/{itemId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── receitas ───────────────────────────────────────────────────────────────
    match /receitas/{receitaId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── condicoes ──────────────────────────────────────────────────────────────
    match /condicoes/{condicaoId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── artes ──────────────────────────────────────────────────────────────────
    match /artes/{arteId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── origens ────────────────────────────────────────────────────────────────
    match /origens/{origemId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── regras ─────────────────────────────────────────────────────────────────
    match /regras/{regraId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── cardflux ───────────────────────────────────────────────────────────────
    match /cardflux/{cardFluxId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── veiasAstrais ───────────────────────────────────────────────────────────
    match /veiasAstrais/{veiaAstralId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── divindades ─────────────────────────────────────────────────────────────
    match /divindades/{divindadeId} {
      allow read: if isAuth();
      allow create: if canWriteUniverso(request.resource.data.universo);
      allow update: if canWriteUniverso(resource.data.universo)
                    && canWriteUniverso(request.resource.data.universo);
      allow delete: if canWriteUniverso(resource.data.universo);
    }

    // ── aptidoes ───────────────────────────────────────────────────────────────
    // Escrita baseada no campo `universos` (lista de ids) do documento —
    // aptidões podem pertencer a mais de um universo.
    match /aptidoes/{aptidaoId} {
      allow read: if isAuth();
      allow create: if canWriteUniversos(request.resource.data.universos);
      allow update: if canWriteAptidaoData(resource.data)
                    && canWriteUniversos(request.resource.data.universos);
      allow delete: if canWriteAptidaoData(resource.data);
    }

    // ── personagens ──────────────────────────────────────────────────────
    // Cada usuário só lê/escreve os próprios personagens (uid == request.auth.uid).
    match /personagens/{personagemId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;

      // Subcoleções (aptidoesAdquiridas, arts, historicoSorte — Fases futuras)
      // herdam a mesma checagem, validando o uid do documento pai.
      match /{subcolecao}/{docId} {
        allow read, write: if isAuth()
          && get(/databases/$(database)/documents/personagens/$(personagemId)).data.uid
             == request.auth.uid;
      }
    }
  }
}
